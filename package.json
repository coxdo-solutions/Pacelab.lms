   "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p $PORT",
    "lint": "next lint",


    "start:dev": "nest start --watch",
    "clean": "rm -rf .next node_modules package-lock.json yarn.lock pnpm-lock.yaml",
    "clean-cache": "rm -rf .next/cache",
    "fresh-install": "npm run clean && npm cache clean --force && npm install",
    "dev:api": "cd apps/api && npm run start:dev",
    "build:api": "cd apps/api && npm run build",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose up",
    "prisma:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=apps/api/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=apps/api/prisma/schema.prisma"
  },
